# Vendored tooling (DESIGN §8) — cloned into var/, not part of the nadir corpus.
var/

# Build artifacts (scons spine emits into build/).
build/
*.obj
*.o
*.exe
*.lst
*.map

# MSVC link incrementals / debug info.
*.ilk
*.pdb

# scons bookkeeping.
.sconsign.dblite
.sconf_temp/

# intent-map DBs: the tracked, canonical ones live in docs/ (documentation
# mechanism — committed, versioned alongside the source they annotate). Working
# copies elsewhere (repo root, var/) and SQLite's transient WAL/SHM sidecars are not.
intent-map.db
*.db-wal
*.db-shm

# Python.
__pycache__/
*.pyc
.pytest_cache/
